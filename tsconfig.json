{
  "compilerOptions": {
    "target": "es2023",
    "allowJs": true,
    "skipLibCheck": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@emotion/react",
    "outDir": "dist",
    "declaration": true,
    "rootDir": "."
  },
  "include": ["./src/**/*"]
}
